# MV Live Translator & Academy - Environment Configuration
# Default: Free-First Architecture (Zero API Keys required out of the box)

# Application Environment
VITE_APP_ENV=production
VITE_APP_NAME="MV Live Translator & Academy"

# AI Provider Configuration (Default: 'free_native')
# Options: 'free_native' | 'gemini_cloud' | 'openai_cloud'
VITE_AI_PROVIDER_TYPE=free_native

# Optional Premium Cloud AI Provider API Keys (Leave blank for Free-First Mode)
VITE_GEMINI_API_KEY=
VITE_OPENAI_API_KEY=
